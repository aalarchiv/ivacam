
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Frontend
frontend/node_modules
frontend/dist
frontend/.svelte-kit
frontend/.vite

# Defensive: catch node_modules / .vite folders that occasionally end
# up outside frontend/ when pnpm is run from the repo root by mistake.
/node_modules/
**/.vite/

# Tauri
crates/ivac-tauri/target
crates/ivac-tauri/gen

# WASM
crates/ivac-wasm/pkg

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Local env
.env
.env.local

# Upstream clones — checked out alongside but not tracked here.
# Bring your own copies via:
#   git clone https://github.com/multigcs/viaconstructor refs/viaconstructor
#   git clone https://github.com/IxMilia/dxf-rs        refs/dxf-rs
refs/
!refs/.gitkeep

# Local Claude-Code session state.
.claude/

# Local Python venv used by tests/golden/refresh.py.
.venv-golden/
**/__pycache__/

# Tempfiles + samples generated during demos.
frontend/public/samples/*-rust.json
frontend/public/samples/*-generated.json
