{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability granting the bundled Vite frontend access to the ivaCAM commands and the dialog/fs plugins it needs for native open/save. Window label is a glob so it also matches the Android/iOS webview (whose label is not necessarily 'main') — otherwise NO permission applies on mobile and every plugin call, including the file dialogs, is denied.",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "store:default",
    "log:default",
    "process:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$HOME/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$HOME/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$TEMP/**"
        }
      ]
    },
    "opener:default"
  ]
}
