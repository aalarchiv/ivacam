{
  "name": "ivac-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "node scripts/ensure-wasm-fresh.mjs && vite",
    "build": "node scripts/ensure-wasm-fresh.mjs && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.node.json",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "codegen": "openapi-typescript ../schema/openapi.yaml -o src/lib/api/generated.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "@types/three": "^0.184.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.10",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "ivac-wasm": "link:../crates/ivac-wasm/pkg",
    "three": "^0.184.0"
  }
}
